# ============================================
# World Cup Insight v2 — Development Dockerfile
# Hot-reload with Vite dev server
# ============================================
# Usage:
#   docker compose up dev       # Start dev with hot-reload
#   docker compose up prod      # Start production build
# ============================================

FROM node:20-alpine

WORKDIR /app

# Copy package files first for better layer caching
COPY package*.json ./

# Install ALL dependencies (including devDependencies)
RUN npm install && npm cache clean --force

# Expose Vite dev server port
EXPOSE 3000

# Start Vite dev server with host flag for Docker
CMD ["npx", "vite", "--host", "--port", "3000"]
